# Project configuration — copy to .env.project and fill in your values
# Edit this before each bootstrap run. .env.project is gitignored.
#
# Setup:
#   cp .env.project.example .env.project
#   # Edit .env.project with your app details
#   bash bootstrap.sh

APP_NAME=MyApp                  # Display name and Xcode scheme
BUNDLE_ID=com.example.myapp     # Reverse-domain bundle identifier
REPO_NAME=myapp                 # GitHub repository name
MINIMUM_IOS=26.0                # Deployment target (optional, defaults to 26.0)
