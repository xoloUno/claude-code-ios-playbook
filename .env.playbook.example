# Playbook configuration — copy to .env.playbook and fill in your values
# Used by bootstrap.sh and referenced throughout the playbook docs
#
# Setup:
#   cp .env.playbook.example .env.playbook
#   # Edit .env.playbook with your real values
#
# .env.playbook is gitignored — your credentials stay local.
#
# You'll also need a per-project .env.fastlane file — see Phase 1.6 in
# ios-project-playbook.md for details.

# Apple Developer Portal → Account (top right) → Membership Details → Team ID
TEAM_ID=YOUR_TEAM_ID

# Your GitHub org or username (used for repo creation)
ORG=YourGitHubOrg

# Your name and contact info (used in generated files)
DEVELOPER_NAME="Your Name"
DEVELOPER_EMAIL=you@example.com
DEVELOPER_DOMAIN=example.com

# App Store Connect → Users and Access → Integrations → App Store Connect API
# Click the key name to see Key ID; Issuer ID is shown at the top of the page
ASC_KEY_ID=YOUR_ASC_KEY_ID
ASC_ISSUER_ID=YOUR_ASC_ISSUER_ID
